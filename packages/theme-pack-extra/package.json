{
  "name": "@mterminal/ext-theme-pack-extra",
  "version": "1.0.2",
  "description": "A small bundle of extra themes shipped with mTerminal",
  "license": "MIT",
  "engines": {
    "mterminal-api": "^1.0.0"
  },
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "typecheck": "node -e \"process.exit(0)\""
  },
  "mterminal": {
    "id": "theme-pack-extra",
    "displayName": "Theme Pack: Extra",
    "activationEvents": [
      "onStartupFinished"
    ],
    "capabilities": [],
    "publisher": {
      "authorId": "gh-61193738",
      "keyId": "gh-61193738:key1"
    },
    "contributes": {
      "themes": [
        {
          "id": "oxocarbon",
