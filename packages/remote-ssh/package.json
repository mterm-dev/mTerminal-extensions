{
  "name": "@mterminal/ext-remote-ssh",
  "version": "1.0.0",
  "description": "Remote SSH host registry, terminal sessions, and SFTP filesystem service",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.cjs",
  "renderer": "dist/renderer.mjs",
  "engines": {
    "mterminal-api": "^1.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@mterminal/extension-api": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "ssh2": "^1.17.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0"
  },
  "devDependencies": {
    "@mterminal/extension-api": "workspace:^",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "mterminal": {
    "id": "remote-ssh",
    "displayName": "Remote SSH",
    "icon": "icons/remote.svg",
    "activationEvents": [
      "onStartupFinished"
    ],
    "capabilities": [
      "child-process",
      "network:limited",
      "filesystem:read"
    ],
    "publisher": {
      "authorId": "gh-61193738",
      "keyId": "gh-61193738:key1"
    },
    "providedServices": {
      "host-registry": {
        "version": "1.0.0"
      },
      "sftp-fs": {
        "version": "1.0.0"
      }
    },
    "contributes": {
      "tabTypes": [
        {
          "id": "remote-ssh-terminal",
          "title": "ssh"
        }
      ],
      "panels": [
        {
          "id": "remote-ssh.hosts",
          "title": "remote",
          "location": "sidebar"
        }
      ],
      "commands": [
        {
          "id": "remoteSsh.openHostsPanel",
          "title": "Remote SSH: open hosts panel"
        },
        {
          "id": "remoteSsh.addHost",
          "title": "Remote SSH: add host"
        }
      ],
      "keybindings": [
        {
          "command": "remoteSsh.openHostsPanel",
          "key": "Ctrl+Shift+G"
        }
      ],
      "secrets": [
        {
          "key": "host:*",
          "title": "saved host passwords"
        }
      ],
      "settings": {
        "type": "object",
        "properties": {
          "idleTimeoutSec": {
            "type": "number",
            "default": 300,
            "minimum": 60,
            "description": "Disconnect idle SSH/SFTP clients after N seconds"
          },
          "maxEntriesPerDir": {
            "type": "number",
            "default": 5000,
            "minimum": 100,
            "description": "Cap entries returned per SFTP directory listing"
          },
          "keepaliveIntervalSec": {
            "type": "number",
            "default": 30,
            "minimum": 5,
            "description": "Send TCP keepalive every N seconds"
          },
          "readyTimeoutMs": {
            "type": "number",
            "default": 10000,
            "minimum": 1000,
            "description": "Connection ready timeout in milliseconds"
          }
        }
      }
    }
  }
}
