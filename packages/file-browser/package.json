{
  "name": "@mterminal/ext-file-browser",
  "version": "1.0.0",
  "description": "Side-panel file browser with full CRUD over local fs and SSH/SFTP",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.cjs",
  "renderer": "dist/renderer.mjs",
  "engines": {
    "mterminal-api": "^1.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@mterminal/extension-api": "^1.0.0",
    "electron": ">=28",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-cpp": "^6.0.2",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-java": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-less": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/lang-php": "^6.0.1",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/language": "^6.10.0",
    "@codemirror/legacy-modes": "^6.4.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.34.0",
    "@lezer/highlight": "^1.2.0",
    "codemirror": "^6.0.1"
  },
  "devDependencies": {
    "@mterminal/extension-api": "workspace:^",
    "@types/node": "^24.0.0",
    "electron": "^33.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5",
    "jsdom": "^29.1.1"
  },
  "mterminal": {
    "id": "file-browser",
    "displayName": "File Browser",
    "icon": "icons/files.svg",
    "activationEvents": [
      "onStartupFinished"
    ],
    "capabilities": [
      "filesystem:read",
      "filesystem:write"
    ],
    "publisher": {
      "authorId": "gh-61193738",
      "keyId": "gh-61193738:key1"
    },
    "consumedServices": {
      "sftp-fs": {
        "versionRange": "^1.0.0",
        "optional": true
      },
      "host-registry": {
        "versionRange": "^1.0.0",
        "optional": true
      }
    },
    "contributes": {
      "tabTypes": [
        {
          "id": "file-browser",
          "title": "files"
        }
      ],
      "commands": [
        {
          "id": "fileBrowser.openInActiveGroup",
          "title": "File Browser: Open in active group"
        }
      ],
      "keybindings": [
        {
          "command": "fileBrowser.openInActiveGroup",
          "key": "Ctrl+B"
        }
      ],
      "settings": {
        "type": "object",
        "properties": {
          "defaultWidth": {
            "type": "number",
            "default": 320,
            "minimum": 200,
            "maximum": 800,
            "description": "Default panel width in pixels"
          },
          "showHiddenByDefault": {
            "type": "boolean",
            "default": true,
            "description": "Show dotfiles by default"
          },
          "maxEntriesPerDir": {
            "type": "number",
            "default": 5000,
            "minimum": 100,
            "description": "Cap entries returned per directory"
          }
        }
      }
    }
  }
}
