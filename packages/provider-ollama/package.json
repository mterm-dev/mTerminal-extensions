{
  "name": "@mterminal/ext-provider-ollama",
  "version": "1.0.0",
  "description": "Ollama AI provider for mTerminal — bundles the official ollama-js package",
  "license": "MIT",
  "type": "module",
  "renderer": "dist/renderer.mjs",
  "engines": {
    "mterminal-api": "^1.4.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@mterminal/extension-api": "^1.4.0"
  },
  "dependencies": {
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@mterminal/extension-api": "workspace:^",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "mterminal": {
    "id": "provider-ollama",
    "displayName": "Ollama",
    "icon": "icons/ollama.svg",
    "activationEvents": ["onStartupFinished"],
    "capabilities": ["network"],
    "providedServices": {
      "ai.sdk.ollama": { "version": "1.0.0" }
    },
    "contributes": {
      "providers": [
        { "kind": "ai", "id": "ollama", "label": "Ollama" }
      ],
      "settings": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "default": "llama3.2",
            "description": "Default Ollama model name."
          },
          "host": {
            "type": "string",
            "default": "http://localhost:11434",
            "description": "Ollama server URL."
          }
        }
      }
    }
  }
}
