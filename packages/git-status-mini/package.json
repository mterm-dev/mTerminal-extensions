{
  "name": "@mterminal/ext-git-status-mini",
  "version": "1.0.1",
  "description": "A small Git status panel \u2014 proof-of-concept for the extension API",
  "license": "MIT",
  "type": "module",
  "renderer": "src/renderer.mjs",
  "engines": {
    "mterminal-api": "^1.0.0"
  },
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "typecheck": "node -e \"process.exit(0)\""
  },
  "mterminal": {
    "id": "git-status-mini",
    "displayName": "Git Status (mini)",
    "activationEvents": [
      "onCommand:gitStatusMini.refresh",
      "onView:git-status-mini"
    ],
    "capabilities": [
      "filesystem:read",
      "child-process"
    ],
    "publisher": {
      "authorId": "gh-61193738",
      "keyId": "gh-61193738:key1"
    },
    "contributes": {
      "panels": [
        {
          "id": "git-status-mini",
          "title": "Git Status (mini)",
          "location": "sidebar.bottom"
        }
      ],
      "statusBar": [
        {
          "id": "gitStatusMini.branch",
          "align": "left",
          "tooltip": "Click to refresh git status",
          "command": "gitStatusMini.refresh"
        }
      ],
      "commands": [
        {
          "id": "gitStatusMini.refresh",
          "title": "Git mini: Refresh status"
        },
        {
          "id": "gitStatusMini.generateMessage",
          "title": "Git mini: Generate AI commit message"
        }
      ],
      "keybindings": [
        {
          "command": "gitStatusMini.refresh",
          "key": "Ctrl+Shift+R"
        }
      ],
      "settings": {
        "type": "object",
        "properties": {
          "refreshIntervalMs": {
            "type": "number",
            "default": 5000,
            "description": "How often to refresh git status while the panel is visible (ms)"
          },
          "commitSystemPrompt": {
            "type": "string",
            "default": "Write a single concise conventional-commit message (under 72 chars on the first line) for the diff that follows. Do not include any extra commentary.",
            "description": "System prompt for the AI commit message generator"
          }
        }
      }
    }
  }
}
