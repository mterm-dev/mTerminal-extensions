{
  "name": "@mterminal/ext-git-panel",
  "version": "1.0.0",
  "description": "Full-featured Git panel for mTerminal",
  "license": "MIT",
  "type": "module",
  "renderer": "dist/renderer.mjs",
  "engines": {
    "mterminal-api": "^1.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@mterminal/extension-api": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@mterminal/extension-api": "workspace:^",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5",
    "jsdom": "^29.1.1"
  },
  "mterminal": {
    "id": "git-panel",
    "displayName": "Git Panel",
    "icon": "icons/git.svg",
    "activationEvents": ["onStartupFinished"],
    "capabilities": [
      "filesystem:read",
      "filesystem:write",
      "child-process",
      "network:limited"
    ],
    "publisher": {
      "authorId": "gh-1319048221",
      "keyId": "gh-1319048221:key1"
    },
    "contributes": {
      "panels": [
        {
          "id": "git-panel",
          "title": "Git",
          "location": "sidebar.bottom",
          "initialCollapsed": false
        }
      ],
      "commands": [
        { "id": "gitPanel.refresh", "title": "Git: Refresh status" },
        { "id": "gitPanel.commit", "title": "Git: Commit" },
        { "id": "gitPanel.commitPush", "title": "Git: Commit and push" },
        { "id": "gitPanel.push", "title": "Git: Push" },
        { "id": "gitPanel.pull", "title": "Git: Pull" },
        { "id": "gitPanel.fetch", "title": "Git: Fetch" },
        { "id": "gitPanel.branches", "title": "Git: Branches" },
        { "id": "gitPanel.history", "title": "Git: History" },
        { "id": "gitPanel.generateMessage", "title": "Git: Generate AI commit message" }
      ],
      "keybindings": [
        { "command": "gitPanel.commit", "key": "Ctrl+Enter", "when": "view == git-panel && !commitMessageEmpty" }
      ],
      "settings": {
        "type": "object",
        "properties": {
          "treeView": {
            "type": "boolean",
            "default": true,
            "description": "Show changes as a tree (vs flat list)"
          },
          "collapsed": {
            "type": "boolean",
            "default": false,
            "description": "Whether the panel starts collapsed"
          },
          "panelHeight": {
            "type": "number",
            "default": 240,
            "description": "Initial panel height in pixels"
          },
          "messageHeight": {
            "type": "number",
            "default": 60,
            "description": "Commit message textarea height"
          },
          "pullStrategy": {
            "type": "string",
            "enum": ["ff-only", "merge", "rebase"],
            "default": "ff-only",
            "description": "Default pull strategy"
          },
          "commitSystemPrompt": {
            "type": "string",
            "default": "Write a single conventional-commit message (under 72 chars on the first line) for the diff. Do not include extra commentary.",
            "description": "System prompt sent to the AI provider"
          }
        }
      },
      "aiBindings": [
        {
          "id": "commit",
          "label": "Commit message generator",
          "description": "Picks the model used by the Generate button. Choose mTerminal's shared AI providers (vault keys) or use a private key scoped to this extension.",
          "supportsCore": true,
          "providers": ["anthropic", "openai", "ollama"],
          "defaultProvider": "anthropic",
          "defaultModels": {
            "anthropic": "claude-sonnet-4-5",
            "openai": "gpt-4o-mini",
            "ollama": "llama3.1"
          }
        }
      ]
    }
  }
}
