{
  "name": "@mterminal/ext-hotbinds",
  "version": "1.0.1",
  "description": "Global hotkey snippets — fire predefined text into the focused input or active terminal",
  "license": "MIT",
  "type": "module",
  "renderer": "dist/renderer.mjs",
  "engines": {
    "mterminal-api": "^1.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@mterminal/extension-api": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@mterminal/extension-api": "workspace:^",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5",
    "jsdom": "^29.1.1"
  },
  "mterminal": {
    "id": "hotbinds",
    "displayName": "Hotbinds",
    "activationEvents": [
      "onStartupFinished"
    ],
    "publisher": {
      "authorId": "gh-61193738",
      "keyId": "gh-61193738:key1"
    },
    "contributes": {
      "commands": [
        {
          "id": "hotbinds.manage",
          "title": "Hotbinds: Manage bindings"
        }
      ],
      "keybindings": [
        {
          "command": "hotbinds.manage",
          "key": "Ctrl+Alt+H"
        }
      ],
      "panels": [
        {
          "id": "hotbinds-panel",
          "title": "Hotbinds",
          "location": "sidebar.bottom",
          "initialCollapsed": true
        }
      ],
      "settings": {
        "type": "object",
        "properties": {
          "bindings": {
            "type": "array",
            "description": "Stored hotkey snippets. Use the manager — open it via Ctrl+Alt+H, the ⌨ Hotbinds entry in the status bar, or the command palette → \"Hotbinds: Manage bindings\". This raw view is read-only and intended for backup/inspection only.",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "key": { "type": "string", "description": "e.g. Ctrl+Alt+1" },
                "text": { "type": "string", "description": "Snippet text to insert" },
                "submit": {
                  "type": "boolean",
                  "default": false,
                  "description": "When firing into a terminal, append Enter to execute"
                }
              }
            }
          }
        }
      }
    }
  }
}
