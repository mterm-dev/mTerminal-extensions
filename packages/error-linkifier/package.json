{
  "name": "@mterminal/ext-error-linkifier",
  "version": "1.0.1",
  "description": "Detects file:line:col patterns in terminal output and exposes a click-to-open command",
  "license": "MIT",
  "renderer": "src/renderer.mjs",
  "type": "module",
  "engines": {
    "mterminal-api": "^1.0.0"
  },
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "typecheck": "node -e \"process.exit(0)\""
  },
  "mterminal": {
    "id": "error-linkifier",
    "displayName": "Error Linkifier",
    "activationEvents": [
      "onStartupFinished"
    ],
    "capabilities": [],
    "publisher": {
      "authorId": "gh-61193738",
      "keyId": "gh-61193738:key1"
    },
    "contributes": {
      "commands": [
        {
          "id": "errorLinkifier.openLast",
          "title": "Error Linkifier: Open last detected file:line"
        }
      ],
      "settings": {
        "type": "object",
        "properties": {
          "openCommand": {
            "type": "string",
            "default": "code +{line}:{col} {file}",
            "description": "Shell template used to open files. Placeholders: {file}, {line}, {col}"
          }
        }
      }
    }
  }
}
